---
import type { CollectionEntry, Heading } from 'astro:content';
import { getCollection } from 'astro:content';

import { PostClick } from '@myriaddreamin/tylant';
import TagList from '$components/TagList.astro';

import BaseHead from '$components/BaseHead.astro';
import Header from '$components/Header.astro';
import Footer from '$components/Footer.astro';
import FormattedDate from '$components/FormattedDate.astro';
import TranslationLink from '$components/TranslationLink.astro';
import Comments from '$components/Comments.astro';
import { kEnableClick, kArticleStats, kEnableReaction } from '$consts';

type Props = CollectionEntry<'blog'>['data'] & {
  id: CollectionEntry<'blog'>['id'];
  slug: CollectionEntry<'blog'>['slug'];
  headings: Heading[];
  translationUrl?: string;
  translationKey: string;
};

const isAboutPage = Astro.url.pathname.includes('/about/');

const {
  id,
  title,
  description,
  date,
  updatedDate,
  tags,
  author,
  lang,
  translationUrl,
  'llm-translated': llmTranslated,
  translationKey,
  headings,
} = Astro.props;
const postSlug = Astro.url.pathname;

// Use frontmatter language as primary source, fallback to URL detection
const currentLang =
  lang || (Astro.url.pathname.startsWith('/zh/') ? 'zh' : 'en');

const stat: { like?: number; click?: number } =
  ((kEnableClick || kEnableReaction) &&
    kArticleStats.find((stat) => stat.id === id)) ||
  {};
const click = stat.click || 0;
const like = stat.like || 0;
const pdfArchives = await getCollection('archive');
---

<html lang={currentLang}>
  <head>
    <BaseHead title={title} description={description} />
    <meta name="translation-key" content={translationKey || ''} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
      integrity="sha384-wcIxkf4k558AjM3Yz3BBFQUbk/zgIYC2R0QpeeYb+TwlBVMrlgLqwRjRtGZiK7ww"
      crossorigin="anonymous"
    />
    <style is:global>
      main {
        padding: 0 0 1em;
      }
      .prose,
      .comment-region,
      ul.tags {
        width: 100%;
        color: var(--main-color);
        margin-left: 0;
        margin-right: 0;
      }
      .prose {
        padding: 0 0 0.25em;
      }
      .prose p {
        margin-block-start: 0.68em;
        margin-block-end: 0.72em;
      }
      .title {
        margin-bottom: 0.45em;
        padding: 0.25em 0 0.15em;
      }
      .title h1 {
        font-size: 2.25em;
        margin: 0 0 0.14em 0;
        line-height: 1.15;
      }
      .article-meta {
        color: var(--main-color);
        display: block;
        margin: 0;
        font-size: 0.82em;
        line-height: 1.35;
      }
      .meta-date {
        margin: 0;
      }
      .meta-language {
        margin: 0.22em 0 0;
        padding-left: 0.7em;
        border-left: 3px solid var(--accent);
      }
      .last-updated-on,
      .click-count,
      .like-count {
        font-style: italic;
      }
      .title .translation-disclaimer {
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
        border: 0 !important;
        background: transparent !important;
        color: inherit !important;
        font: inherit !important;
        line-height: inherit !important;
      }
      .title .translation-disclaimer a {
        color: var(--accent) !important;
      }
      .title hr {
        display: none;
      }
      .prose > h1:first-of-type,
      .prose > h2:first-of-type,
      .title + h1,
      .title + h2 {
        margin-block-start: 0.45em;
      }
      ul.tags {
        list-style: none;
        padding: 0;
        margin-top: 0.15em;
        margin-bottom: 1.1em;
      }
      .tags li {
        display: inline-block;
        margin: 0;
        margin-right: 1em;
      }
      .tags a {
        text-decoration: none;
      }
      .tags a:hover {
        text-decoration: underline;
      }
      .prose > p:last-child {
        margin-bottom: 0.2em;
      }
    </style>
    {id && kEnableClick && <PostClick id={id} />}
  </head>

  <body>
    <Header articleId={id || undefined} />
    <main>
      <article>
        <div class="prose">
          <section class="title" aria-label="Title">
            <h1>{title}</h1>
            <div class="article-meta">
              <div class="meta-date">
                <FormattedDate date={date} />
                {
                  updatedDate && (
                    <>
                      <span class="last-updated-on">
                        · updated{' '}
                        <FormattedDate date={updatedDate || date} />
                      </span>
                    </>
                  )
                }
                {
                  id && kEnableClick && (
                    <>
                      <span> · </span>
                      <span class="click-count">
                        {click} {click === 1 ? 'view' : 'views'}
                      </span>
                    </>
                  )
                }
                {
                  id && kEnableReaction && (
                    <>
                      <span> · </span>
                      <span class="like-count">
                        {like} {like === 1 ? 'like' : 'likes'}
                      </span>
                    </>
                  )
                }
              </div>
              <div class="meta-language">
                {
                  !isAboutPage && (
                    <TranslationLink
                      entry={Astro.props}
                      locale={currentLang}
                      llmTranslated={llmTranslated}
                    />
                  )
                }
              </div>
            </div>
          </section>
          <slot />
        </div>
      </article>
      {tags && <TagList tags={tags} lang={lang || currentLang} />}
      {
        !isAboutPage && (
          <div class="comment-region">
            <Comments owner="pxwg" repo="blog" title={translationKey} />
          </div>
        )
      }
    </main>
    <Footer />
  </body>
</html>
