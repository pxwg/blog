---
import BaseHead from "$components/BaseHead.astro";
import HomeIntro from "$components/HomeIntro.astro";
import {
  kSiteTitle,
  kSiteDescription,
  kBaiduVeriCode,
} from "$consts";
import { getSafeLanguageConfig } from "$utils/i18n";

export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "zh" } }
  ];
}

const { lang } = Astro.params;
const currentLang = lang === "zh" ? "zh" : "en";
const config = getSafeLanguageConfig("index", currentLang);

---

<!doctype html>
<html lang={config.htmlLang}>
  <head>
    <BaseHead title={kSiteTitle} description={kSiteDescription} />
    {
      kBaiduVeriCode && (
        <meta name="baidu-site-verification" content={kBaiduVeriCode} />
      )
    }
  </head>
  <body>
    <HomeIntro lang={currentLang} />
  </body>
</html>
