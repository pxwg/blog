---
import { kUrlBase } from "$consts";

const today = new Date();
---

<footer>
  <div>&copy; 2025-{today.getFullYear()} Xinyu Xiang. All rights reserved.</div>
  <nav class="footer-links" aria-label="Footer links">
    <a href="https://github.com/pxwg" target="_blank" rel="noreferrer">github</a>
    <a href={`${kUrlBase}/rss.xml`} target="_blank" rel="noreferrer">rss</a>
  </nav>
</footer>
<style>
  footer {
    padding: 1.8em 1em 4em;
    background: var(--nav-bg-color);
    color: var(--main-color);
    text-align: center;
    font-size: 0.9em;
  }
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 0.85em;
    margin-top: 0.35em;
    font-size: 0.9em;
  }
  .footer-links a {
    color: var(--accent);
  }
</style>
