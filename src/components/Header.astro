---
import { kUrlBase, kSiteLogo } from "$consts";
import { ThemeToggle } from "@myriaddreamin/tylant-theme-toggle";
import HeaderLink from "./HeaderLink.astro";
import LanguageToggle from "./LanguageToggle.astro";

interface Props {
  articleId?: string;
}

const { articleId } = Astro.props;

// Get current locale from URL
const currentLocale = Astro.url.pathname.startsWith('/zh/') ? 'zh' : 'en';

// Generate localized URLs
const localizedUrls = {
  home: currentLocale === 'zh' ? `${kUrlBase}/zh/` : `${kUrlBase}/en/`,
  posts: currentLocale === 'zh' ? `${kUrlBase}/zh/article/` : `${kUrlBase}/en/article/`,
  friends: currentLocale === 'zh' ? `${kUrlBase}/zh/friend/` : `${kUrlBase}/en/friend/`,
  about: currentLocale === 'zh' ? `${kUrlBase}/zh/about/` : `${kUrlBase}/en/about/`
};

// Localized text
const localizedText = {
  home: currentLocale === 'zh' ? '首页' : 'home',
  posts: currentLocale === 'zh' ? '文章' : 'posts',
  friends: currentLocale === 'zh' ? '友链' : 'friends',
  about: currentLocale === 'zh' ? '关于' : 'about'
};
---

<header>
  <nav class="site-nav">
    <h2 class="logo"><a href={localizedUrls.home}>{kSiteLogo}</a></h2>
    <div class="internal-links" aria-label="Primary navigation">
      <HeaderLink href={localizedUrls.home}>{localizedText.home}</HeaderLink>
      <HeaderLink href={localizedUrls.posts}>{localizedText.posts}</HeaderLink>
      <HeaderLink href={localizedUrls.friends}>{localizedText.friends}</HeaderLink>
      <HeaderLink href={localizedUrls.about}>{localizedText.about}</HeaderLink>
    </div>
    <div class="site-actions" aria-label="Site actions">
      <LanguageToggle articleId={articleId} />
      <a
        href="https://github.com/pxwg/blog"
        target="_blank"
        rel="noreferrer"
        title="Go to the repository of this blog"
      >
        github
      </a>
      <span class="theme-action"><ThemeToggle lightIcon="light" darkIcon="dark" /></span>
    </div>
  </nav>
</header>

<style>
  .logo {
    font-size: 1em;
    font-weight: 700;
    font-style: italic;
    letter-spacing: 0;
  }
  header {
    margin: 0;
    padding: 0.6rem 0 0.35rem;
    background: var(--nav-bg-color);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  .site-nav {
    width: min(var(--content-width), calc(100% - var(--page-gutter)));
    max-width: 100%;
    margin: auto;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 0.95em;
    row-gap: 0.12em;
  }
  .site-actions,
  .internal-links {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 0.72em;
    row-gap: 0.12em;
  }
  .site-actions {
    justify-content: flex-start;
    font-size: 0.86em;
    color: var(--gray-color);
  }
  .site-actions > * + *::before {
    content: "·";
    color: var(--gray-color);
    margin-right: 0.75em;
  }
  .internal-links::before,
  .site-actions::before {
    content: "/";
    color: var(--gray-color);
    margin-right: 0.05em;
  }
  .internal-links {
    font-size: 0.86em;
  }
  :global(html:lang(zh)) .internal-links a {
    font-size: calc(1em * var(--vp-zh-prose-scale, 0.93));
    line-height: calc(1.55 / var(--vp-zh-prose-scale, 0.93));
  }
  .site-nav a {
    padding: 0;
    border: 0;
    color: var(--accent);
  }
  .site-nav a.active {
    color: var(--accent);
  }
  .logo a,
  .logo a.active {
    color: var(--main-color);
    text-decoration: none;
  }
  :global(#theme-toggle) {
    display: inline;
    padding: 0;
    border: 0;
    color: var(--accent);
    font: inherit;
    line-height: inherit;
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.12em;
    vertical-align: baseline;
  }
  :global(#theme-toggle:hover) {
    color: var(--accent-dark);
    text-decoration-color: var(--accent-dark);
    text-decoration-thickness: 0.12em;
  }
  :global(#theme-toggle .theme-icon) {
    line-height: inherit;
  }
  :global(.dark #theme-toggle .theme-icon.light) {
    display: inline;
  }
  :global(.dark #theme-toggle .theme-icon.dark) {
    display: none;
  }
  :global(#theme-toggle .theme-icon.light) {
    display: none;
  }
  :global(#theme-toggle .theme-icon.dark) {
    display: inline;
  }
  @media (max-width: 680px) {
    header {
      padding-top: 0.5rem;
    }
    .site-nav {
      row-gap: 0.05em;
    }
  }
  @media (max-width: 400px) {
    .site-nav {
      font-size: 14px;
    }
  }
</style>
