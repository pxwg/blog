---
import { kUrlBase, kSiteLogo } from "$consts";
import { ThemeToggle } from "@myriaddreamin/tylant-theme-toggle";
import { generateLanguageToggleUrl } from "$utils/i18n";

interface Props {
  articleId?: string;
}

const pathWithoutBase = kUrlBase && Astro.url.pathname.startsWith(`${kUrlBase}/`)
  ? Astro.url.pathname.slice(kUrlBase.length)
  : Astro.url.pathname;
const currentLocale = pathWithoutBase.startsWith('/zh/') ? 'zh' : 'en';
const targetLocale = currentLocale === 'zh' ? 'en' : 'zh';

// Generate localized URLs
const localizedUrls = {
  home: currentLocale === 'zh' ? `${kUrlBase}/zh/` : `${kUrlBase}/en/`,
  posts: currentLocale === 'zh' ? `${kUrlBase}/zh/article/` : `${kUrlBase}/en/article/`,
  friends: currentLocale === 'zh' ? `${kUrlBase}/zh/friend/` : `${kUrlBase}/en/friend/`,
  about: currentLocale === 'zh' ? `${kUrlBase}/zh/about/` : `${kUrlBase}/en/about/`
};

const routeParts = pathWithoutBase.split('/').filter(Boolean);
const pageParts = routeParts[0] === 'zh' || routeParts[0] === 'en'
  ? routeParts.slice(1)
  : routeParts;
const currentSection = pageParts[0] === 'article'
  ? 'posts'
  : pageParts[0] === 'friend'
    ? 'friends'
    : pageParts[0] === 'about'
      ? 'about'
      : 'home';

const currentSectionUrl = localizedUrls[currentSection as keyof typeof localizedUrls];
const languageToggleUrl = `${kUrlBase}${generateLanguageToggleUrl(pathWithoutBase, targetLocale)}`;
const languageLabel = currentLocale === 'zh' ? 'en' : 'cn';
---

<header>
  <nav class="newspaper-nav" aria-label="Site navigation">
    <div class="nav-left">
      <a class="site-mark" href={localizedUrls.home}>{kSiteLogo}</a>
      <span class="nav-separator" aria-hidden="true">|</span>
      <a class="nav-link section-link" href={currentSectionUrl}>{currentSection}</a>
      <span class="nav-separator" aria-hidden="true">|</span>
      <a class="nav-link language-link" href={languageToggleUrl}>{languageLabel}</a>
    </div>
    <span class="theme-action"><ThemeToggle lightIcon="light" darkIcon="dark" /></span>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0.58rem 0 0.38rem;
    background: var(--nav-bg-color);
  }
  .newspaper-nav {
    width: min(var(--content-width), calc(100% - var(--page-gutter)));
    max-width: 100%;
    margin: auto;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1em;
    color: var(--main-color);
    font-size: 0.96em;
    line-height: 1.38;
  }
  .nav-left {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 0.44em;
    row-gap: 0.1em;
  }
  .site-mark,
  .nav-link {
    color: var(--main-color);
    font-style: normal;
    line-height: inherit;
    text-decoration-line: underline;
    text-decoration-color: currentColor;
    text-decoration-thickness: 0.07em;
    text-underline-offset: 0.16em;
  }
  .site-mark {
    font-size: 1em;
    font-weight: 600;
    white-space: nowrap;
  }
  .nav-link {
    font-size: 1em;
    font-weight: 400;
  }
  .site-mark:hover {
    color: var(--main-hover-color);
    text-decoration-color: currentColor;
  }
  .nav-link:hover,
  :global(#theme-toggle:hover) {
    color: var(--main-hover-color);
    text-decoration-color: currentColor;
  }
  .nav-separator {
    color: var(--main-color);
  }
  .theme-action {
    margin-left: auto;
    white-space: nowrap;
  }
  :global(#theme-toggle) {
    display: inline;
    padding: 0;
    border: 0;
    color: var(--main-color);
    font: inherit;
    line-height: inherit;
    text-decoration-line: underline;
    text-decoration-color: currentColor;
    text-decoration-thickness: 0.07em;
    text-underline-offset: 0.16em;
    vertical-align: baseline;
  }
  :global(#theme-toggle .theme-icon) {
    line-height: inherit;
  }
  :global(.dark #theme-toggle .theme-icon.light) {
    display: inline;
  }
  :global(.dark #theme-toggle .theme-icon.dark) {
    display: none;
  }
  :global(#theme-toggle .theme-icon.light) {
    display: none;
  }
  :global(#theme-toggle .theme-icon.dark) {
    display: inline;
  }
  @media (max-width: 680px) {
    header {
      padding-top: 0.58rem;
    }
    .newspaper-nav {
      gap: 0.6em;
    }
  }
</style>
