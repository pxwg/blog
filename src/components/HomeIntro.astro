---
import { kSiteTitle, kUrlBase } from "$consts";

interface Props {
  lang: "en" | "zh";
}

const { lang } = Astro.props;

const homeTags = ["physics", "math", "programming", "prose"];

const tagHref = (tag: string) => {
  const params = new URLSearchParams({ search: tag });
  return `${kUrlBase}/${lang}/article/?${params}`;
};

const randomTagOptions = homeTags.map((tag) => ({
  label: `#${tag}`,
  href: tagHref(tag),
}));
const fallbackTag = randomTagOptions[Math.floor(Math.random() * randomTagOptions.length)] ?? randomTagOptions[0];
const randomTagOptionsJson = JSON.stringify(randomTagOptions);
const allPostsHref = `${kUrlBase}/${lang}/article/`;
const profileLinks = [
  {
    label: lang === "zh" ? "知乎" : "Zhihu",
    href: "https://www.zhihu.com/people/bu-hui-fei-de-qi-e-71",
    external: true,
  },
  {
    label: "Github",
    href: "https://github.com/pxwg",
    external: true,
  },
  {
    label: "friends",
    href: `${kUrlBase}/${lang}/friend/`,
    external: false,
  },
  {
    label: "about",
    href: `${kUrlBase}/${lang}/about/`,
    external: false,
  },
];

const tagNavLabel = lang === "zh" ? "文章标签" : "Article tags";
const profileNavLabel = lang === "zh" ? "外部链接" : "Profile links";
const homeHeroLabel =
  lang === "zh"
    ? "彩霞云层与天空的插图"
    : "Rosy clouds across the sky";
---

<main class="home-minimal" aria-label={kSiteTitle}>
  <div class="home-hero" role="img" aria-label={homeHeroLabel}></div>
  <h1>{kSiteTitle}</h1>
  <p class="home-motto">I believe, since I remember.</p>
  <nav class="home-line home-tags" aria-label={tagNavLabel} data-random-tags={randomTagOptionsJson}>
    <span class="home-link-group">
      <a href={allPostsHref}>all posts</a>
    </span>
    <span class="home-link-group">
      <span class="home-separator" aria-hidden="true">|</span>
      <a class="random-tag-link" href={fallbackTag.href}>{fallbackTag.label}</a>
    </span>
  </nav>
  <nav class="home-line home-profiles" aria-label={profileNavLabel}>
    {
      profileLinks.map((link, index) => (
        <span class="home-link-group">
          {index > 0 && <span class="home-separator" aria-hidden="true">|</span>}
          {
            link.external
              ? <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              : <a href={link.href}>{link.label}</a>
          }
        </span>
      ))
    }
  </nav>
</main>

<style>
  .home-minimal {
    box-sizing: border-box;
    width: min(34rem, calc(100% - var(--page-gutter)));
    min-height: 100svh;
    margin: auto;
    padding: clamp(2rem, 8vh, 5rem) 0 clamp(5rem, 18vh, 10rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .home-hero {
    width: 100%;
    aspect-ratio: 4 / 1;
    margin: 0 0 clamp(1rem, 3vw, 1.45rem);
    overflow: hidden;
    background-image: url("/images/homeward-sky-hero-light.webp");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  :global(.dark) .home-hero {
    background-image: url("/images/homeward-sky-hero.webp");
    background-position: center 44%;
  }

  .home-minimal h1 {
    margin: 0 0 0.28em;
    font-size: 3.4rem;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .home-motto {
    margin: 0 0 0.9em;
    color: var(--main-color);
    font-size: 1.08em;
    line-height: 1.35;
  }

  .home-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.42em;
    margin: 0.08em 0;
    line-height: 1.55;
  }

  .home-link-group {
    display: inline-flex;
    align-items: baseline;
    gap: 0.42em;
    white-space: nowrap;
  }

  .home-profiles {
    margin-top: 0.18em;
  }

  .home-separator {
    color: var(--gray-color);
  }

  @media (max-width: 520px) {
    .home-minimal {
      width: min(100% - 1.6rem, 34rem);
      padding: 2.5rem 0 3.75rem;
    }

    .home-minimal h1 {
      font-size: 2.65rem;
    }

    .home-tags {
      font-size: 0.96em;
    }

    .home-tags .home-link-group {
      gap: 0.36em;
    }
  }

  @media (max-width: 360px) {
    .home-minimal h1 {
      font-size: 2.45rem;
    }
  }

  @media (max-width: 340px) {
    .home-profiles {
      column-gap: 0.65em;
    }

    .home-profiles .home-link-group {
      gap: 0;
    }

    .home-profiles .home-separator {
      display: none;
    }
  }
</style>

<script>
  const randomTagNav = document.querySelector<HTMLElement>("[data-random-tags]");
  const randomTagLink = randomTagNav?.querySelector<HTMLAnchorElement>(".random-tag-link");
  const randomTagOptions = JSON.parse(randomTagNav?.dataset.randomTags ?? "[]");
  const randomTag = randomTagOptions[Math.floor(Math.random() * randomTagOptions.length)];

  if (randomTag && randomTagLink) {
    randomTagLink.href = randomTag.href;
    randomTagLink.textContent = randomTag.label;
  }
</script>
