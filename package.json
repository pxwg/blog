{
  "name": "pxwg",
  "type": "module",
  "version": "0.0.5",
  "workspaces": [
    ".",
    "packages/tylant/packages/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "TYPST_FONT_PATHS=assets/fonts:public/fonts:. TYPST_FONT_PATH=assets/fonts astro build",
    "build:deploy": "bash scripts/setup-fonts.sh && npm run build",
    "preview": "astro preview",
    "create:post": "node scripts/create-file.mjs blog-post",
    "create:archive": "node scripts/create-file.mjs archive-post",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.13",
    "@astrojs/sitemap": "^3.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@myriaddreamin/tylant": "workspace:^",
    "@myriaddreamin/tylant-theme-toggle": "workspace:^",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "astro": "^5.15.4",
    "astro-typst": "0.12.3",
    "dotenv": "^17.2.3",
    "katex": "^0.16.25",
    "lxgw-wenkai-webfont": "^1.7.0",
    "marked": "^16.4.2",
    "preact": "^10.27.2",
    "vite-plugin-static-copy": "^3.1.4"
  },
  "devDependencies": {
    "vite": "^6.4.1"
  }
}
